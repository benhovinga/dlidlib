{
  "name": "@benhovinga/dlidlib",
  "version": "0.1.0-alpha",
  "description": "Library to parse data in the barcode found on the back of North American identification and driver license cards.",
  "author": "Benjamin P.C. Hovinga",
  "license": "MIT",
  "private": false,
  "keywords": [
    "library",
    "aamva",
    "driver license",
    "identification card",
    "barcode",
    "pdf417"
  ],
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
