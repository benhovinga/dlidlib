{
  "name": "@benhovinga/dlidlib",
  "version": "0.2.0-beta",
  "description": "Library to parse data in the barcode found on the back of North American identification and driver license cards.",
  "author": "Benjamin P.C. Hovinga",
  "license": "MIT",
  "keywords": [
    "library",
    "aamva",
    "driver license",
    "identification card",
    "barcode",
    "pdf417"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/benhovinga/dlidlib.git"
  },
  "bugs": {
    "url": "https://github.com/benhovinga/dlidlib/issues"
  },
  "homepage": "https://github.com/benhovinga/dlidlib#readme",
  "files": [
    "dist",
    "src",
    "!src/**/*.spec.ts"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "scripts": {
    "build": "pnpm clean:build && tsc",
    "clean:build": "rimraf dist",
    "clean:coverage": "rimraf coverage",
    "clean:package": "rimraf -g benhovinga-dlidlib-*.tgz",
    "clean:modules": "rimraf node_modules",
    "clean:all": "pnpm clean:build && pnpm clean:coverage && pnpm clean:package && pnpm clean:modules",
    "test": "vitest",
    "test:ci": "vitest run --reporter=minimal",
    "test:coverage": "vitest run --coverage",
    "format": "prettier . --write",
    "lint": "eslint",
    "prepack": "pnpm lint && pnpm test:ci && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "^10.5.0",
    "jiti": "^2.7.0",
    "prettier": "3.8.4",
    "rimraf": "^6.1.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
